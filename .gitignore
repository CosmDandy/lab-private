.DS_Store
.env
!*.env.tpl
secrets/

# Sing-box TLS certs
stacks/vpn-legacy/sing-box/tls/

# Generated sing-box client configs (from .jsonnet)
stacks/vpn-legacy/sing-box/client-*.json.tpl

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/tfplan
terraform/secrets.auto.tfvars

# Backups (contain sensitive data)
backups/
