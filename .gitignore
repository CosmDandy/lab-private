.DS_Store
.env
secrets/

# Ansible
ansible/roles/*/files/*.tgz
ansible/roles/*/files/*.zip

# Sing-box TLS certs
configs/vpn/*/sing-box/tls/

# Generated sing-box client configs (from .jsonnet)
configs/vpn/*/sing-box/client-*.json.tpl

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/tfplan
terraform/secrets.auto.tfvars
