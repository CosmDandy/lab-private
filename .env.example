# =============================================================================
# GitHub Repository Variables (Settings → Secrets → Variables)
# =============================================================================

# Server IPs
VPN_SERVER_IP=1.2.3.4              # VPN server public IP
MESH_SERVER_IP=5.6.7.8             # Mesh server public IP

# Domains
VPN_DOMAIN=vpn.example.com         # Domain for client config distribution
MESH_DOMAIN=mesh.example.com       # Domain for headscale/headplane
BASE_DOMAIN=example.com            # Base domain for DNS extra records
MESH_BASE_DOMAIN=hamster            # MagicDNS base domain (internal)
ACME_EMAIL=admin@example.com       # Let's Encrypt email

# Reality (public part)
REALITY_PUBLIC_KEY=<generate>       # sing-box generate reality-keypair

# =============================================================================
# GitHub Repository Secrets (Settings → Secrets → Actions)
# =============================================================================

# sing-box credentials
VLESS_UUID=<uuidgen>
REALITY_PRIVATE_KEY=<generate>      # sing-box generate reality-keypair
REALITY_SHORT_ID=<generate>         # sing-box generate rand 8 --hex
HY2_PASSWORD=<generate>
SALAMANDER_PASSWORD=<generate>
TUIC_PASSWORD=<generate>
SHADOWTLS_PASSWORD=<generate>       # sing-box generate rand 32 --base64
SS_PASSWORD=<generate>              # sing-box generate rand 16 --base64
TROJAN_PASSWORD=<generate>
SS_PLAIN_PASSWORD=<generate>        # sing-box generate rand 16 --base64

# Caddy basic auth
CADDY_VPN_USER=admin
CADDY_VPN_HASH=<caddy hash-password>
CADDY_MESH_USER=admin
CADDY_MESH_HASH=<caddy hash-password>

# Headplane
HEADPLANE_COOKIE_SECRET=<exactly 32 characters>
